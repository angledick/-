# Astra — 跨境合规智能体 环境配置
DATABASE_URL=postgresql+asyncpg://astra:astra@localhost:5432/astra

# ════════════════════════════════════════════════════════════
# Claude Agent SDK — 完整配置
# ════════════════════════════════════════════════════════════

# Claude API Key (claude-agent-sdk 认证用，必填)
ANTHROPIC_API_KEY=

# SDK 启停
SDK_ENABLED=true

# 会话与模型
SDK_SESSION_ID=
SDK_RESUME_SESSION=
SDK_CONTINUE_CONVERSATION=false
SDK_FORK_SESSION=false
SDK_MODEL=
SDK_FALLBACK_MODEL=
SDK_MAX_TURNS=0
SDK_MAX_BUDGET_USD=0.0
SDK_CWD=.\

# 工具与权限
SDK_ALLOWED_TOOLS=Read,Write,Edit,Bash,Glob,Grep,WebSearch,WebFetch
SDK_DISALLOWED_TOOLS=
SDK_PERMISSION_MODE=bypassPermissions

# 子代理配置 (JSON)
SDK_AGENTS_JSON=

# 技能 (JSON 数组或 "all")
SDK_SKILLS_JSON=

# 沙箱 (JSON)
SDK_SANDBOX_JSON=

# 钩子
SDK_INCLUDE_HOOK_EVENTS=false

# Beta 功能 (JSON 数组)
SDK_BETAS_JSON=

# CLI 参数
SDK_CLI_PATH=
SDK_EXTRA_ARGS_JSON=
SDK_ADD_DIRS_JSON=
SDK_ENV_JSON=
SDK_ENABLE_FILE_CHECKPOINTING=false
SDK_STRICT_MCP_CONFIG=false
SDK_SETTING_SOURCES_JSON=
SDK_USER=

DEBUG=true