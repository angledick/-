      "tool_type": "builtin",
      "category": "compliance",
      "config": {
        "pipeline_mode": "6step",
        "auto_notify": true
      },
      "enabled": true,
      "updated_at": "2026-06-03T04:31:29.854397+00:00"
    },
    {
      "id": "tool_cert_monitor",
      "name": "认证监控",
      "description": "监控产品认证到期状态",
      "tool_type": "builtin",
      "category": "certification",
      "config": {
        "advance_days": 30,
        "check_interval": "daily"
      },
      "enabled": true
    },
    {
      "id": "tool_hs_lookup",
      "name": "HS编码查询",
