{"name":"工厂代工合同","description":"OEM/ODM 生产委托合同，适用于委托工厂按规格生产","contract_type":"oem","variables":[{"key":"buyer_name","label":"委托方名称","required":true},{"key":"buyer_address","label":"委托方地址","required":true},{"key":"seller_name","label":"受托方（工厂）名称","required":true},{"key":"seller_address","label":"工厂地址","required":true},{"key":"product_name","label":"产品名称","required":true},{"key":"product_spec","label":"产品规格要求","required":true},{"key":"hs_code","label":"HS 编码","required":true},{"key":"quantity","label":"生产数量","required":true},{"key":"unit_price","label":"代工单价","required":true},{"key":"currency","label":"货币","default":"CNY"},{"key":"total_amount","label":"合同总金额","required":true},{"key":"delivery_date","label":"完成交货日期","required":true},{"key":"payment_terms","label":"付款条件","default":"30% 预付，验货合格后支付70%"},{"key":"brand_authorization","label":"品牌使用授权（如有）","default":"无品牌授权要求"},{"key":"contract_date","label":"合同日期","required":true}]}
