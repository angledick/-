{"name":"货代服务合同","description":"委托货代/物流公司提供国际运输及报关服务","contract_type":"logistics","variables":[{"key":"shipper_name","label":"委托方（货主）","required":true},{"key":"shipper_address","label":"委托方地址","required":true},{"key":"forwarder_name","label":"货代公司名称","required":true},{"key":"forwarder_address","label":"货代公司地址","required":true},{"key":"cargo_name","label":"货物名称","required":true},{"key":"hs_code","label":"HS 编码","required":true},{"key":"origin_port","label":"起运港","required":true},{"key":"dest_country","label":"目的国","required":true},{"key":"incoterm","label":"贸易术语","default":"FOB"},{"key":"freight_amount","label":"运费金额","required":true},{"key":"currency","label":"货币","default":"USD"},{"key":"service_scope","label":"服务范围","default":"出口报关、订舱、海运干线、目的港清关"},{"key":"contract_date","label":"合同日期","required":true}]}
